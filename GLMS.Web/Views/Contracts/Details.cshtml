@model Contract
@{
    ViewData["Title"] = Model.Title;
    bool canRaise = Model.Status == ContractStatus.Active;
}

<div class="page-header">
    <div class="page-header-left">
        <a asp-action="Index" class="back-btn" title="Back to Contracts">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-subtitle">@Model.Client?.Name &mdash; <span class="badge-level badge-@Model.ServiceLevel">@Model.ServiceLevel</span></p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-secondary-glms">
            <i class="bi bi-pencil"></i> Edit
        </a>
        @if (canRaise)
        {
            <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.Id" class="btn-primary-glms">
                <i class="bi bi-plus-lg"></i> Raise Request
            </a>
        }
    </div>
</div>

<div class="row g-4">

    <!-- Left column: details + status + file -->
    <div class="col-lg-4">
        <div class="glms-card">
            <div class="glms-card-header">
                <span class="glms-card-title">Contract Details</span>
                <span class="badge-status badge-@Model.Status">@Model.Status</span>
            </div>
            <div class="glms-card-body">
                <dl class="detail-list">
                    <dt>Start Date</dt>
                    <dd>@Model.StartDate.ToString("dd MMMM yyyy")</dd>
                    <dt>End Date</dt>
                    <dd>@Model.EndDate.ToString("dd MMMM yyyy")</dd>
                    <dt>Service Level</dt>
                    <dd><span class="badge-level badge-@Model.ServiceLevel">@Model.ServiceLevel</span></dd>
                    <dt>Created On</dt>
                    <dd class="text-muted-sm">@Model.CreatedOn.ToString("dd MMM yyyy, HH:mm") UTC</dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                {
                    <hr class="divider" />
                    <p class="form-label-glms mb-2">Signed Agreement</p>
                    <a asp-action="DownloadAgreement" asp-route-id="@Model.Id" class="btn-secondary-glms" style="font-size:0.8rem;">
                        <i class="bi bi-file-earmark-pdf"></i> Download PDF
                    </a>
                    <p class="form-hint mt-1">@Model.SignedAgreementFileName</p>
                }
            </div>
        </div>

        <!-- Status update -->
        <div class="glms-card">
            <div class="glms-card-header">
                <span class="glms-card-title">Update Status</span>
            </div>
            <div class="glms-card-body">
                <p class="form-hint mb-2">Current status: <strong>@Model.Status</strong></p>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="status-btn-group">
                        @foreach (var status in Enum.GetValues<ContractStatus>())
                        {
                            if (status != Model.Status)
                            {
                                <button type="submit" name="newStatus" value="@status" class="btn-status">
                                    @status
                                </button>
                            }
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right column: service requests -->
    <div class="col-lg-8">
        <div class="glms-card" style="margin-bottom:0;">
            <div class="glms-card-header">
                <span class="glms-card-title">Service Requests (@Model.ServiceRequests.Count)</span>
                @if (!canRaise)
                {
                    <span class="text-muted-sm">Only available on Active contracts</span>
                }
            </div>
            <div class="glms-card-body" style="padding:0;">
                <table class="glms-table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>USD Amount</th>
                            <th>ZAR Amount</th>
                            <th>Status</th>
                            <th>Raised</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sr in Model.ServiceRequests)
                        {
                            <tr>
                                <td>@sr.Description</td>
                                <td class="text-muted-sm">$@sr.CostUsd.ToString("N2")</td>
                                <td class="zar-amount">R @sr.CostZar.ToString("N2")</td>
                                <td><span class="badge-status badge-@sr.Status">@sr.Status</span></td>
                                <td class="text-muted-sm">@sr.RaisedOn.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                        @if (!Model.ServiceRequests.Any())
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">
                                        <div>No service requests have been raised on this contract.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
