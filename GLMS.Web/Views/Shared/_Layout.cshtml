<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GLMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="glms-wrapper">

    <!-- Sidebar -->
    <aside class="glms-sidebar">
        <a asp-controller="Home" asp-action="Index" class="sidebar-brand">
            <span class="brand-icon">GL</span>
            GLMS
        </a>

        <div class="sidebar-section">
            <div class="sidebar-label">Main</div>
            <a asp-controller="Home" asp-action="Index" class="sidebar-nav-link">
                <i class="bi bi-bar-chart-line nav-icon"></i>
                Dashboard
            </a>
            <a asp-controller="Clients" asp-action="Index" class="sidebar-nav-link">
                <i class="bi bi-people nav-icon"></i>
                Clients
            </a>
            <a asp-controller="Contracts" asp-action="Index" class="sidebar-nav-link">
                <i class="bi bi-file-earmark-text nav-icon"></i>
                Contracts
            </a>
            <a asp-controller="ServiceRequests" asp-action="Index" class="sidebar-nav-link">
                <i class="bi bi-clipboard-check nav-icon"></i>
                Service Requests
            </a>
        </div>

        <div class="sidebar-footer">
            TechMove GLMS &copy; 2026<br />
            <span style="font-size:0.68rem; opacity:0.6;">ST10538419</span>
        </div>
    </aside>

    <!-- Main content -->
    <main class="glms-main">

        @if (TempData["Success"] is not null)
        {
            <div class="alert-glms alert-glms-success mb-4">
                <i class="bi bi-check-circle-fill" style="flex-shrink:0; margin-top:1px;"></i>
                <span>@TempData["Success"]</span>
            </div>
        }
        @if (TempData["Error"] is not null)
        {
            <div class="alert-glms alert-glms-danger mb-4">
                <i class="bi bi-exclamation-triangle-fill" style="flex-shrink:0; margin-top:1px;"></i>
                <span>@TempData["Error"]</span>
            </div>
        }

        @RenderBody()

    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<!-- Mark active sidebar links -->
<script>
    (function () {
        var path = window.location.pathname.toLowerCase();
        document.querySelectorAll('.sidebar-nav-link').forEach(function (link) {
            var href = link.getAttribute('href');
            if (href && href !== '/' && path.startsWith(href.toLowerCase())) {
                link.classList.add('active');
            } else if (href === '/' && (path === '/' || path === '')) {
                link.classList.add('active');
            }
        });
    })();
</script>
</body>
</html>
