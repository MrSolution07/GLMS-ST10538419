@model Client
@{
    ViewData["Title"] = "Delete Client";
}

<div class="page-header">
    <div class="page-header-left">
        <a asp-action="Index" class="back-btn" title="Back to Clients">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="page-title">Delete Client</h1>
    </div>
</div>

<div class="danger-card">
    <div class="danger-card-header">
        <h6><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion</h6>
    </div>
    <div style="padding:1.25rem;">
        <p style="font-size:0.875rem; color:#5a607a; margin-bottom:1rem;">
            This will permanently remove the client record. All linked contracts will be retained but unlinked.
        </p>
        <dl class="detail-list" style="margin-bottom:1.25rem;">
            <dt>Name</dt><dd>@Model.Name</dd>
            <dt>Email</dt><dd>@Model.ContactEmail</dd>
            <dt>Region</dt><dd>@Model.Region</dd>
            <dt>Linked Contracts</dt><dd>@Model.Contracts.Count</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn-danger-glms">Confirm Delete</button>
                <a asp-action="Index" class="btn-secondary-glms">Cancel</a>
            </div>
        </form>
    </div>
</div>
