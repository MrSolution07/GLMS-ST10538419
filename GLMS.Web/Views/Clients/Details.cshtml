@model Client
@{
    ViewData["Title"] = Model.Name;
}

<div class="page-header">
    <div class="page-header-left">
        <a asp-action="Index" class="back-btn" title="Back to Clients">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h1 class="page-title">@Model.Name</h1>
            <p class="page-subtitle">@Model.Region</p>
        </div>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-secondary-glms">
        <i class="bi bi-pencil"></i> Edit Client
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="glms-card" style="margin-bottom:0;">
            <div class="glms-card-header">
                <span class="glms-card-title">Contact Information</span>
            </div>
            <div class="glms-card-body">
                <dl class="detail-list">
                    <dt>Email</dt>
                    <dd>@Model.ContactEmail</dd>
                    <dt>Phone</dt>
                    <dd>@(Model.ContactPhone ?? "—")</dd>
                    <dt>Region</dt>
                    <dd>@Model.Region</dd>
                    <dt>Registered On</dt>
                    <dd>@Model.RegisteredOn.ToString("dd MMMM yyyy")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="glms-card" style="margin-bottom:0;">
            <div class="glms-card-header">
                <span class="glms-card-title">Contracts (@Model.Contracts.Count)</span>
                <a asp-controller="Contracts" asp-action="Create" class="btn-primary-glms" style="font-size:0.8rem; padding:0.35rem 0.75rem;">
                    <i class="bi bi-plus-lg"></i> New Contract
                </a>
            </div>
            <div class="glms-card-body" style="padding:0;">
                <table class="glms-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Service Level</th>
                            <th>Status</th>
                            <th>End Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Contracts)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Contracts" asp-action="Details" asp-route-id="@c.Id"
                                       class="fw-table-primary text-decoration-none" style="color:var(--accent);">
                                        @c.Title
                                    </a>
                                </td>
                                <td><span class="badge-level badge-@c.ServiceLevel">@c.ServiceLevel</span></td>
                                <td><span class="badge-status badge-@c.Status">@c.Status</span></td>
                                <td class="text-muted-sm">@c.EndDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                        @if (!Model.Contracts.Any())
                        {
                            <tr>
                                <td colspan="4">
                                    <div class="empty-state">
                                        <div>No contracts linked to this client.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
